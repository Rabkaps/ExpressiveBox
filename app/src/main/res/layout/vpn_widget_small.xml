<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="8dp"
    android:gravity="center_vertical"
    android:theme="@style/Theme.ExpressiveBox"
    android:background="@drawable/widget_background_pill">

    <!-- Small Node Status Icon -->
    <ImageView
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/ic_node"
        android:tint="?attr/colorPrimary"
        android:layout_marginEnd="10dp" />

    <!-- Connection Status Text -->
    <TextView
        android:id="@+id/widget_status"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="UNPROTECTED"
        android:textColor="?attr/colorOutline"
        android:textSize="15sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:textStyle="bold"
        android:letterSpacing="0.02" />

    <!-- Toggle Power Button -->
    <ImageView
        android:id="@+id/widget_button_toggle"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/widget_button_background"
        android:src="@drawable/ic_power"
        android:padding="8dp"
        android:scaleType="fitCenter"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Toggle Connection" />

</LinearLayout>
